# NizamCraft Apache Server Configuration
# Disable browser caching for HTML, CSS, and Javascript files to prevent caching issues on cPanel
<IfModule mod_headers.c>
    <FilesMatch "\.(html|css|js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>
